# onchain-attribution-kit environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Server ---
# Secret key required in the Authorization header when posting events.
# Generate a random string: openssl rand -hex 32
ONCHAIN_ATTRIBUTION_WRITE_KEY=

# Port the local server listens on
PORT=3000

# --- Storage ---
# Path to the append-only JSONL event store (relative to project root)
EVENTS_FILE=data/events.jsonl

# Attribution window in days. Events older than this are considered expired.
ATTRIBUTION_WINDOW_DAYS=7

# --- Alert channels ---
# Comma-separated list of channels to send alerts to.
# Options: telegram, discord, slack
ALERT_CHANNELS=telegram

# --- Telegram ---
# Get a bot token from @BotFather on Telegram.
# See docs/telegram.md for setup instructions.
TELEGRAM_BOT_TOKEN=

# The chat ID or channel ID to send alerts to.
# Use @userinfobot to find your chat ID.
TELEGRAM_CHAT_ID=

# --- Discord ---
# Create a webhook in your Discord server Settings > Integrations > Webhooks.
# See docs/discord.md for setup instructions.
DISCORD_WEBHOOK_URL=

# --- Slack ---
# Create an incoming webhook at https://api.slack.com/apps.
# See docs/slack.md for setup instructions.
SLACK_WEBHOOK_URL=
