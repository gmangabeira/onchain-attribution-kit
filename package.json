{
  "name": "onchain-attribution-kit",
  "version": "0.1.0",
  "description": "Open-source onchain attribution for Web3 growth teams. Capture UTMs at wallet connect, join campaigns to Dune activity, and send alerts to Telegram, Discord, or Slack.",
  "main": "dist/server/api.js",
  "scripts": {
    "dev": "ts-node src/server/api.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts --ext .ts",
    "test:alert": "ts-node scripts/send-test-alert.ts --dry-run --channel all",
    "import:events": "ts-node scripts/import-events-csv.ts"
  },
  "keywords": [
    "web3",
    "attribution",
    "onchain",
    "utm",
    "wallet",
    "dune",
    "telegram",
    "discord",
    "slack",
    "defi",
    "growth",
    "marketing",
    "open-source"
  ],
  "author": "Gabriel Mangabeira <gabriel@mangabeira.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gmangabeira/onchain-attribution-kit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
